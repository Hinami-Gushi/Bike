@model List<Bike.Models.FuelLog>

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Dashboard";

    var lang = Context.Session.GetString("lang") ?? "en";

    var avg = (double)(ViewBag.AverageFuelEfficiency ?? 0d);
    var totalFuel = (double)(ViewBag.TotalFuel ?? 0d);
    var monthCost = (double)(ViewBag.MonthlyFuelCost ?? 0d);
    var totalDistance = (double)(ViewBag.TotalDistance ?? 0d);
    var latest = (double)(ViewBag.LatestEfficiency ?? 0d);

    string currencyLabel = Context.Session.GetString("currency") ?? "USD";
    string langLabel = (lang == "ja") ? "JA" : (lang == "vi") ? "VI" : "EN";

    // Translations
    var t = new Dictionary<string, Dictionary<string, string>>
    {
        ["en"] = new() {
            ["Dashboard"] = "Dashboard", ["Add"] = "Add", ["History"] = "History", ["Monthly"] = "Monthly",
            ["AvgEfficiency"] = "AVG EFFICIENCY", ["TotalFuel"] = "TOTAL FUEL", ["MonthCost"] = "THIS MONTH COST", 
            ["TotalDistance"] = "TOTAL DISTANCE", ["LatestEfficiency"] = "LATEST EFFICIENCY", ["AddFuelLog"] = "＋ Add Fuel Log",
            ["Logout"] = "Logout"
        },
        ["ja"] = new() {
            ["Dashboard"] = "ダッシュボード", ["Add"] = "追加", ["History"] = "履歴", ["Monthly"] = "月間集計",
            ["AvgEfficiency"] = "平均燃費", ["TotalFuel"] = "総給油量", ["MonthCost"] = "今月の燃料費", 
            ["TotalDistance"] = "総走行距離", ["LatestEfficiency"] = "直近の燃費", ["AddFuelLog"] = "＋ 給油記録を追加",
            ["Logout"] = "ログアウト"
        },
        ["vi"] = new() {
            ["Dashboard"] = "Bảng điều khiển", ["Add"] = "Thêm", ["History"] = "Lịch sử", ["Monthly"] = "Hàng tháng",
            ["AvgEfficiency"] = "HIỆU SUẤT TRUNG BÌNH", ["TotalFuel"] = "TỔNG NHIÊN LIỆU", ["MonthCost"] = "CHI PHÍ THÁNG NÀY", 
            ["TotalDistance"] = "TỔNG QUÃNG ĐƯỜNG", ["LatestEfficiency"] = "HIỆU SUẤT MỚI NHẤT", ["AddFuelLog"] = "＋ Thêm Nhật ký Nhiên liệu",
            ["Logout"] = "Đăng xuất"
        }
    };
    var currentT = t.ContainsKey(lang) ? t[lang] : t["en"];

    var userEmail = Context.Session.GetString("userEmail") ?? "";
}

<link rel="stylesheet" href="~/css/map.css">

<div class="bfl-page">

    <!-- TOP -->
    <div class="bfl-topbar">
        <div class="bfl-brand">
            <div class="bfl-brand-title is-clickable" data-bs-toggle="modal" data-bs-target="#bikeImageModal">🏍 Bike Fuel Log</div>
            <div class="bfl-brand-sub">@userEmail</div>
        </div>

        <div class="bfl-topbar-actions">
            <div class="bfl-pill">@currencyLabel</div>
            <a href="/Account/Logout" class="bfl-pill bfl-pill-logout" style="text-decoration:none; background:#fee2e2; color:#991b1b;">@currentT["Logout"]</a>
            <div class="bfl-pill bfl-pill-currency">@currencyLabel</div>

            <div class="dropdown">
                <button class="bfl-pill dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown">
                    @langLabel
                </button>

                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/Language/Set?lang=en">English</a></li>
                    <li><a class="dropdown-item" href="/Language/Set?lang=ja">日本語</a></li>
                    <li><a class="dropdown-item" href="/Language/Set?lang=vi">Tiếng Việt</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- NAV -->
    <div class="bfl-nav">
        <a class="bfl-nav-item is-active" href="/FuelLogs/Dashboard">Dashboard</a>
        <a class="bfl-nav-item" href="/FuelLogs/Create">Add</a>
        <a class="bfl-nav-item" href="/FuelLogs/Index">History</a>
        <a class="bfl-nav-item" href="/FuelLogs/Monthly">Monthly</a>
    </div>

    <!-- CONTENT -->
    <div class="bfl-content">

        <!-- STATS -->
        <div class="bfl-grid">

            <div class="bfl-card">
                <div class="bfl-card-title">⚡ Avg Efficiency</div>
                <div class="bfl-card-value">@avg.ToString("0.0") km/L</div>
            </div>

            <div class="bfl-card">
                <div class="bfl-card-title">💧 Total Fuel</div>
                <div class="bfl-card-value">@totalFuel.ToString("0.0") L</div>
            </div>

            <div class="bfl-card">
                <div class="bfl-card-title">💲 Monthly Cost</div>
                <div class="bfl-card-value">@monthCost.ToString("#,0") @currencyLabel</div>
            </div>

            <div class="bfl-card">
                <div class="bfl-card-title">📏 Distance</div>
                <div class="bfl-card-value">@totalDistance.ToString("#,0") km</div>
            </div>

        </div>

        <!-- LATEST -->
        <div class="bfl-card bfl-card-wide">
            <div class="bfl-card-title">🔥 Latest Efficiency</div>
            <div class="bfl-card-value">@latest.ToString("0.00") km/L</div>
        </div>

        <!-- BUTTON -->
        <a class="bfl-primary-action" href="/FuelLogs/Create">
            ＋ Add Fuel Log
        </a>

        <!-- MAP SECTION -->
        <div class="bfl-card bfl-card-wide">

            <div class="bfl-card-title">
                ⛽ Nearby Gas Stations
            </div>

            <button id="find-gas-button" type="button">
                近くのガソリンスタンドを探す
            </button>

            <div id="map" style="height: 400px; width: 100%;"></div>

        </div>

    </div>
</div>

<!-- Google Maps API（これ1つだけ！重要） -->
<script src="https://maps.googleapis.com/maps/api/js?key=YOUR_API_KEY&libraries=places&language=ja">
</script>

<!-- JS -->
<script src="~/js/map.js"></script>