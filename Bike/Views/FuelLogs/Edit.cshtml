@model Bike.Models.FuelLog

@{
    ViewData["Title"] = "Edit Log";

    var lang = Context.Session.GetString("lang") ?? "en";
    string currencyLabel = Model.Currency ?? "VND";
    var fuelDate = (Model?.FuelDate ?? DateTime.Today).ToString("yyyy-MM-dd");

    // Translations
    var t = new Dictionary<string, Dictionary<string, string>>
    {
        ["en"] = new() { ["EditTitle"] = "Edit Fuel Log", ["Date"] = "Date", ["Fuel"] = "Fuel (L)", ["Distance"] = "Distance (km)", ["Cost"] = "Cost", ["Currency"] = "Currency", ["Save"] = "Save", ["Back"] = "Back" },
        ["ja"] = new() { ["EditTitle"] = "給油記録の編集", ["Date"] = "日付", ["Fuel"] = "給油量 (L)", ["Distance"] = "走行距離 (km)", ["Cost"] = "金額", ["Currency"] = "通貨", ["Save"] = "保存", ["Back"] = "戻る" },
        ["vi"] = new() { ["EditTitle"] = "Sửa Nhật ký Nhiên liệu", ["Date"] = "Ngày", ["Fuel"] = "Nhiên liệu (L)", ["Distance"] = "Quãng đường (km)", ["Cost"] = "Chi phí", ["Currency"] = "Tiền tệ", ["Save"] = "Lưu", ["Back"] = "Quay lại" }
    };
    var currentT = t.ContainsKey(lang) ? t[lang] : t["en"];
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-lg">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <h2 class="h4 mb-0 fw-bold">@currentT["EditTitle"]</h2>
                </div>

                <form method="post">
                    <input type="hidden" name="Id" value="@Model.Id" />

                    <div class="mb-4">
                        <label class="form-label">@currentT["Date"]</label>
                        <input class="form-control form-control-lg shadow-sm" type="date" name="FuelDate" value="@fuelDate" required />
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label class="form-label">@currentT["Fuel"]</label>
                            <div class="input-group shadow-sm">
                                <input class="form-control border-end-0" type="number" step="0.1" min="0" name="FuelLiter" value="@Model.FuelLiter" required />
                                <span class="input-group-text bg-white text-muted border-start-0">L</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label">@currentT["Distance"]</label>
                            <div class="input-group shadow-sm">
                                <input class="form-control border-end-0" type="number" step="0.1" min="0" name="DistanceKm" value="@Model.DistanceKm" required />
                                <span class="input-group-text bg-white text-muted border-start-0">km</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">@currentT["Cost"]</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white text-muted border-end-0">@currencyLabel</span>
                            <input class="form-control border-start-0" type="number" step="1" min="0" name="Cost" value="@Model.Cost" />
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label">@currentT["Currency"]</label>
                        <input class="form-control shadow-sm" type="text" name="Currency" value="@currencyLabel" />
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-lg py-3 shadow-lg" type="submit">
                            <i class="bi bi-check2-circle me-1"></i> @currentT["Save"]
                        </button>
                        <a href="/FuelLogs/Index" class="btn btn-light btn-lg py-3 border">
                            @currentT["Back"]
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
