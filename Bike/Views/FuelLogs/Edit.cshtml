@model Bike.Models.FuelLog

@{
	Layout = "_AppLayout";
	ViewData["Title"] = "Edit";

	var lang = Context.Session.GetString("lang") ?? "en";
	string currencyLabel = Model.Currency ?? "VND";
	string langLabel = (lang == "ja") ? "JA" : (lang == "vi") ? "VI" : "EN";
	var fuelDate = (Model?.FuelDate ?? DateTime.Today).ToString("yyyy-MM-dd");
}

<div class="bfl-page">
	<div class="bfl-topbar">
		<div class="bfl-brand">
			<div class="bfl-brand-title">🏍 Bike Fuel Log</div>
			<div class="bfl-brand-sub">QTSC Field Tracker</div>
		</div>

		<div class="bfl-topbar-actions">
			<div class="bfl-pill bfl-pill-currency">@currencyLabel</div>

			<div class="dropdown">
				<button class="bfl-pill bfl-pill-lang dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
					@langLabel
				</button>
				<ul class="dropdown-menu dropdown-menu-end">
					<li><a class="dropdown-item" href="/Language/Set?lang=en">English</a></li>
					<li><a class="dropdown-item" href="/Language/Set?lang=ja">日本語</a></li>
					<li><a class="dropdown-item" href="/Language/Set?lang=vi">Tiếng Việt</a></li>
				</ul>
			</div>
		</div>
	</div>

	<div class="bfl-nav">
		<a class="bfl-nav-item" href="/FuelLogs/Dashboard">
			<span class="bfl-nav-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M12 3l9 8h-3v10h-5v-6H11v6H6V11H3l9-8z" /></svg>
			</span>
			<span class="bfl-nav-text">Dashboard</span>
		</a>

		<a class="bfl-nav-item is-active" href="#">
			<span class="bfl-nav-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm18-11.5a1.003 1.003 0 0 0 0-1.42l-1.34-1.34a1.003 1.003 0 0 0-1.42 0l-1.13 1.13 3.75 3.75 1.14-1.12z" /></svg>
			</span>
			<span class="bfl-nav-text">Edit</span>
		</a>

		<a class="bfl-nav-item" href="/FuelLogs">
			<span class="bfl-nav-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M7 6h14v2H7V6zm0 5h14v2H7v-2zm0 5h14v2H7v-2zM3 6h2v2H3V6zm0 5h2v2H3v-2zm0 5h2v2H3v-2z" /></svg>
			</span>
			<span class="bfl-nav-text">History</span>
		</a>

		<a class="bfl-nav-item" href="/FuelLogs/Monthly">
			<span class="bfl-nav-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2zm13 8H6v10h14V10z" /></svg>
			</span>
			<span class="bfl-nav-text">Monthly</span>
		</a>
	</div>

	<div class="bfl-content">
		<div class="bfl-card bfl-form-card">
			<div class="bfl-form-title">✏️ Edit Fuel Log</div>

			<form method="post" class="bfl-form">
				<input type="hidden" name="Id" value="@Model.Id" />

				<div class="bfl-field">
					<label class="bfl-label">Date <span class="bfl-required">*</span></label>
					<input class="bfl-input" type="date" name="FuelDate" value="@fuelDate" required />
				</div>

				<div class="bfl-row">
					<div class="bfl-field">
						<label class="bfl-label">Fuel (L) <span class="bfl-required">*</span></label>
						<input class="bfl-input" type="number" step="0.1" min="0" name="FuelLiter" value="@Model.FuelLiter" required />
					</div>

					<div class="bfl-field">
						<label class="bfl-label">Distance (km) <span class="bfl-required">*</span></label>
						<input class="bfl-input" type="number" step="0.1" min="0" name="DistanceKm" value="@Model.DistanceKm" required />
					</div>
				</div>

				<div class="bfl-field">
					<label class="bfl-label">Cost (optional)</label>
					<input class="bfl-input" type="number" step="0.1" min="0" name="Cost" value="@Model.Cost" />
				</div>

				<div class="bfl-field">
					<label class="bfl-label">Currency</label>
					<input class="bfl-input" type="text" name="Currency" value="@currencyLabel" />
				</div>

				<button class="bfl-submit" type="submit">Save</button>
				<a class="bfl-link" href="/FuelLogs">Back</a>
			</form>
		</div>
	</div>
</div>
