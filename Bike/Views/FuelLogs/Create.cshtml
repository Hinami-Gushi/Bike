@model Bike.Models.FuelLog

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Add";


    var lang = Context.Session.GetString("lang") ?? "en";
    string currencyLabel = Context.Session.GetString("currency") ?? "USD";
    string langLabel = (lang == "ja") ? "JA" : (lang == "vi") ? "VI" : "EN";

    var fuelDate = (Model?.FuelDate ?? DateTime.Today).ToString("yyyy-MM-dd");

    var t = new Dictionary<string, Dictionary<string, string>>
    {
        ["en"] = new()
        {
            ["Dashboard"] = "Dashboard",
            ["Add"] = "Add",
            ["History"] = "History",
            ["Monthly"] = "Monthly",
            ["AddTitle"] = "Add Fuel Log",
            ["Date"] = "Date",
            ["Cost"] = "Cost",
            ["Save"] = "Save",
            ["Region"] = "Region",
            ["Vietnam"] = "Vietnam",
            ["Japan"] = "Japan",
            ["FullTank"] = "Full Tank"
        },

        ["ja"] = new() {
            ["Dashboard"] = "ダッシュボード",
            ["Add"] = "追加",
            ["History"] = "履歴",
            ["Monthly"] = "月次",
            ["AddTitle"] = "給油記録の追加", ["Date"] = "日付", ["Cost"] = "金額", ["Save"] = "保存",
            ["Region"] = "地域", ["Vietnam"] = "ベトナム", ["Japan"] = "日本", ["FullTank"] = "満タン"
=======
        ["ja"] = new()
        {
            ["Dashboard"] = "ダッシュボード",
            ["Add"] = "追加",
            ["History"] = "履歴",
            ["Monthly"] = "月間集計",
            ["AddTitle"] = "給油記録の追加",
            ["Date"] = "日付",
            ["Cost"] = "金額",
            ["Save"] = "保存",
            ["Region"] = "地域",
            ["Vietnam"] = "ベトナム",
            ["Japan"] = "日本",
            ["FullTank"] = "満タン"

        },
        ["vi"] = new()
        {
            ["Dashboard"] = "Bảng điều khiển",
            ["Add"] = "Thêm",
            ["History"] = "Lịch sử",
            ["Monthly"] = "Hàng tháng",
            ["AddTitle"] = "Thêm Nhật ký Nhiên liệu",
            ["Date"] = "Ngày",
            ["Cost"] = "Chi phí",
            ["Save"] = "Lưu",
            ["Region"] = "Vùng",
            ["Vietnam"] = "Việt Nam",
            ["Japan"] = "Nhật Bản",
            ["FullTank"] = "Đầy bình"
        }
    };

    var currentT = t.ContainsKey(lang) ? t[lang] : t["en"];
}

<div class="bfl-page">

    <!-- TOP BAR -->
    <div class="bfl-topbar">
        <div class="bfl-brand">
            <div class="bfl-brand-title">🏍 Bike Fuel Log</div>
            <div class="bfl-brand-sub">QTSC Field Tracker</div>
        </div>

        <div class="bfl-topbar-actions">
            <div class="bfl-pill">@currencyLabel</div>
        </div>
    </div>

    <!-- NAV -->
    <div class="bfl-nav">
        <a class="bfl-nav-item" href="/FuelLogs/Dashboard">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 3l9 8h-3v10h-5v-6H11v6H6V11H3l9-8z" /></svg>
            </span>
            <span class="bfl-nav-text">@currentT["Dashboard"]</span>
        </a>

        <a class="bfl-nav-item is-active" href="/FuelLogs/Create">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M19 11H13V5h-2v6H5v2h6v6h2v-6h6v-2z" /></svg>
            </span>
            <span class="bfl-nav-text">@currentT["Add"]</span>
        </a>

        <a class="bfl-nav-item" href="/FuelLogs">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7 6h14v2H7V6zm0 5h14v2H7v-2zm0 5h14v2H7v-2zM3 6h2v2H3V6zm0 5h2v2H3v-2zm0 5h2v2H3v-2z" /></svg>
            </span>
            <span class="bfl-nav-text">@currentT["History"]</span>
        </a>

        <a class="bfl-nav-item" href="/FuelLogs/Monthly">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2zm13 8H6v10h14V10z" /></svg>
            </span>
            <span class="bfl-nav-text">@currentT["Monthly"]</span>
        </a>
        <a class="bfl-nav-item" href="/FuelLogs/Dashboard">@currentT["Dashboard"]</a>
        <a class="bfl-nav-item is-active" href="/FuelLogs/Create">@currentT["Add"]</a>
        <a class="bfl-nav-item" href="/FuelLogs">@currentT["History"]</a>
        <a class="bfl-nav-item" href="/FuelLogs/Monthly">@currentT["Monthly"]</a>
    </div>

    <!-- CONTENT -->
    <div class="bfl-content">

        <div class="bfl-card">

            <div class="bfl-form-title">
                🧾 @currentT["AddTitle"]
            </div>

            <form asp-action="Create" method="post" id="fuelForm">

                <!-- location -->
                <input type="hidden" name="Latitude" id="Latitude" />
                <input type="hidden" name="Longitude" id="Longitude" />
                <input type="hidden" name="Region" id="Region" value="VN" />

                <!-- date -->
                <div>
                    <label>Date</label>
                    <input asp-for="FuelDate" type="date" value="@fuelDate" required />
                </div>

                <!-- fuel -->
                <div>
                    <label>Fuel Amount</label>
                    <input asp-for="FuelLiter" type="number" step="0.1" required />
                </div>

                <!-- distance -->
                <div>
                    <label>Distance</label>
                    <input asp-for="DistanceKm" type="number" step="0.1" required />
                </div>

                <!-- cost -->
                <div>
                    <label>Cost</label>
                    <input asp-for="Cost" type="number" step="1" id="CostInput" required />
                </div>

                <!-- submit -->
                <button type="submit">Save</button>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setCost(val){
            document.getElementById("CostInput").value = val;
        }

        function getLocation(){
            if(navigator.geolocation){
                navigator.geolocation.getCurrentPosition(function(pos){
                    document.getElementById("Latitude").value = pos.coords.latitude;
                    document.getElementById("Longitude").value = pos.coords.longitude;
                });
            }
        }

        window.onload = getLocation;
    </script>
}