@model Bike.Models.FuelLog

<h1>Add Fuel Log</h1>

<form method="post">

    <p>
        Date
        <input type="date" name="FuelDate" />
    </p>

    <p>
        Fuel Amount
        <input type="number" step="0.1" name="FuelLiter" />
    </p>

    <p>
        Distance
        <input type="number" step="0.1" name="DistanceKm" />
    </p>

    <p>
        Cost
        <input type="number" step="0.1" name="Cost" />
    </p>

    <button type="submit">Save</button>

</form>