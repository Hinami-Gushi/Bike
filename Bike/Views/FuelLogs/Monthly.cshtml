@{
    ViewData["Title"] = "Monthly Summary";

    var lang = Context.Session.GetString("lang") ?? "en";
    string currencyLabel = Context.Session.GetString("currency") ?? "USD";
    var summaries = ViewBag.MonthlySummaries;

    // Translations
    var t = new Dictionary<string, Dictionary<string, string>>
    {
        ["en"] = new() { ["MonthlyTitle"] = "Monthly Summary", ["Badge"] = "Recent months", ["Fuel"] = "Fuel", ["Distance"] = "Distance", ["Efficiency"] = "Efficiency", ["Cost"] = "Cost" },
        ["ja"] = new() { ["MonthlyTitle"] = "月間集計", ["Badge"] = "直近の月", ["Fuel"] = "給油量", ["Distance"] = "走行距離", ["Efficiency"] = "平均燃費", ["Cost"] = "費用" },
        ["vi"] = new() { ["MonthlyTitle"] = "Tổng kết hàng tháng", ["Badge"] = "Các tháng gần đây", ["Fuel"] = "Nhiên liệu", ["Distance"] = "Quãng đường", ["Efficiency"] = "Hiệu suất", ["Cost"] = "Chi phí" }
    };
    var currentT = t.ContainsKey(lang) ? t[lang] : t["en"];
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h1 class="h3 mb-0">@currentT["MonthlyTitle"]</h1>
        <p class="text-muted small mb-0">Performance breakdown by month</p>
    </div>
    <div class="col-auto">
        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success border-opacity-10">
            <i class="bi bi-calendar-check me-1"></i> @currentT["Badge"]
        </span>
    </div>
</div>

<div class="row g-4">
    @if (summaries != null)
    {
        @foreach (var s in summaries)
        {
            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm overflow-hidden h-100">
                    <div class="card-header bg-white border-0 p-4 pb-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0 text-success">@s.MonthYear</h5>
                            <div class="badge bg-warning bg-opacity-10 text-warning fs-6">
                                @s.TotalCost.ToString("N0") @currencyLabel
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <div class="row text-center g-3">
                            <div class="col-4">
                                <div class="p-3 rounded-4 bg-light border-0">
                                    <div class="text-muted small fw-bold mb-1 text-uppercase">@currentT["Fuel"]</div>
                                    <div class="fw-bold text-dark h5 mb-0">@s.TotalFuel.ToString("0.0")<small class="ms-1">L</small></div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-3 rounded-4 bg-light border-0">
                                    <div class="text-muted small fw-bold mb-1 text-uppercase">@currentT["Distance"]</div>
                                    <div class="fw-bold text-dark h5 mb-0">@s.TotalDistance.ToString("0.0")<small class="ms-1">km</small></div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-3 rounded-4 bg-success bg-opacity-10 border-0">
                                    <div class="text-success small fw-bold mb-1 text-uppercase">@currentT["Efficiency"]</div>
                                    <div class="fw-bold text-success h5 mb-0">@s.AverageEfficiency.ToString("0.0")<small class="ms-1">km/L</small></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="progress rounded-0" style="height: 4px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <div class="bg-white p-5 rounded-4 shadow-sm border d-inline-block">
                <i class="bi bi-calendar-x fs-1 text-muted"></i>
                <p class="mt-3 mb-0 fw-bold text-muted">No monthly summaries available.</p>
            </div>
        </div>
    }
</div>
