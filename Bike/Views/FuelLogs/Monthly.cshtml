@{
	Layout = "_AppLayout";
	ViewData["Title"] = "Monthly";
}

<div class="bfl-page">
	<div class="bfl-topbar">
		<div class="bfl-brand">
			<div class="bfl-brand-title">🏍 Bike Fuel Log</div>
			<div class="bfl-brand-sub">QTSC Field Tracker</div>
		</div>

		<div class="bfl-topbar-actions">
			<div class="bfl-pill bfl-pill-currency">VND</div>
			<div class="bfl-pill bfl-pill-lang">EN</div>
		</div>
	</div>

	<div class="bfl-nav">
		<a class="bfl-nav-item" href="/FuelLogs/Dashboard">
			<span class="bfl-nav-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M12 3l9 8h-3v10h-5v-6H11v6H6V11H3l9-8z"/></svg>
			</span>
			<span class="bfl-nav-text">Dashboard</span>
		</a>

		<a class="bfl-nav-item" href="/FuelLogs/Create">
			<span class="bfl-nav-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M19 11H13V5h-2v6H5v2h6v6h2v-6h6v-2z"/></svg>
			</span>
			<span class="bfl-nav-text">Add</span>
		</a>

		<a class="bfl-nav-item" href="/FuelLogs">
			<span class="bfl-nav-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M7 6h14v2H7V6zm0 5h14v2H7v-2zm0 5h14v2H7v-2zM3 6h2v2H3V6zm0 5h2v2H3v-2zm0 5h2v2H3v-2z"/></svg>
			</span>
			<span class="bfl-nav-text">History</span>
		</a>

		<a class="bfl-nav-item is-active" href="/FuelLogs/Monthly">
			<span class="bfl-nav-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2zm13 8H6v10h14V10z"/></svg>
			</span>
			<span class="bfl-nav-text">Monthly</span>
		</a>
	</div>

	<div class="bfl-content">
		<div class="bfl-card">
			<div class="bfl-card-title">Monthly</div>
			<div class="text-muted">この画面は枠のみです（後で集計を追加）</div>
		</div>
	</div>
</div>
