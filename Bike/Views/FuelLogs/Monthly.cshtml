@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Monthly";

    var lang = Context.Session.GetString("lang") ?? "en";
    string currencyLabel = Context.Session.GetString("currency") ?? "USD";
    string langLabel = (lang == "ja") ? "JA" : (lang == "vi") ? "VI" : "EN";

    double totalFuel = ViewBag.TotalFuel;
    double totalDistance = ViewBag.TotalDistance;
    double totalCost = ViewBag.TotalCost;
    double averageEfficiency = ViewBag.AverageEfficiency;
    string monthYear = ViewBag.MonthYear;

    // Translations
    var t = new Dictionary<string, Dictionary<string, string>>
    {
        ["en"] = new() {
            ["Dashboard"] = "Dashboard", ["Add"] = "Add", ["History"] = "History", ["Monthly"] = "Monthly",
            ["MonthlyTitle"] = "Monthly Cost", ["Badge"] = "1 month", ["Fuel"] = "fuel", ["Distance"] = "distance", ["Efficiency"] = "efficiency"
        },
        ["ja"] = new() {
            ["Dashboard"] = "ダッシュボード", ["Add"] = "追加", ["History"] = "履歴", ["Monthly"] = "月間集計",
            ["MonthlyTitle"] = "月間燃料費", ["Badge"] = "1ヶ月間", ["Fuel"] = "給油量", ["Distance"] = "距離", ["Efficiency"] = "燃費"
        },
        ["vi"] = new() {
            ["Dashboard"] = "Bảng điều khiển", ["Add"] = "Thêm", ["History"] = "Lịch sử", ["Monthly"] = "Hàng tháng",
            ["MonthlyTitle"] = "Chi phí hàng tháng", ["Badge"] = "1 tháng", ["Fuel"] = "nhiên liệu", ["Distance"] = "quãng đường", ["Efficiency"] = "hiệu suất"
        }
    };
    var currentT = t.ContainsKey(lang) ? t[lang] : t["en"];
}

<div class="bfl-page">
    <div class="bfl-topbar">
        <div class="bfl-brand">
            <div class="bfl-brand-title is-clickable" data-bs-toggle="modal" data-bs-target="#bikeImageModal">🏍 Bike Fuel Log</div>
            <div class="bfl-brand-sub">QTSC Field Tracker</div>
        </div>

        <div class="bfl-topbar-actions">
            <div class="bfl-pill bfl-pill-currency" style="background: #14532d; color: #ffffff; border: none;">@currencyLabel</div>

            <div class="dropdown">
                <button class="bfl-pill bfl-pill-lang dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    @langLabel
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/Language/Set?lang=en">English</a></li>
                    <li><a class="dropdown-item" href="/Language/Set?lang=ja">日本語</a></li>
                    <li><a class="dropdown-item" href="/Language/Set?lang=vi">Tiếng Việt</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="bfl-nav">
        <a class="bfl-nav-item" href="/FuelLogs/Dashboard">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 3l9 8h-3v10h-5v-6H11v6H6V11H3l9-8z" /></svg>
            </span>
            <span class="bfl-nav-text">@currentT["Dashboard"]</span>
        </a>

        <a class="bfl-nav-item" href="/FuelLogs/Create">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M19 11H13V5h-2v6H5v2h6v6h2v-6h6v-2z" /></svg>
            </span>
            <span class="bfl-nav-text">@currentT["Add"]</span>
        </a>

        <a class="bfl-nav-item" href="/FuelLogs">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7 6h14v2H7V6zm0 5h14v2H7v-2zm0 5h14v2H7v-2zM3 6h2v2H3V6zm0 5h2v2H3v-2zm0 5h2v2H3v-2z" /></svg>
            </span>
            <span class="bfl-nav-text">@currentT["History"]</span>
        </a>

        <a class="bfl-nav-item is-active" href="/FuelLogs/Monthly">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2zm13 8H6v10h14V10z" /></svg>
            </span>
            <span class="bfl-nav-text">@currentT["Monthly"]</span>
        </a>
    </div>

    <div class="bfl-content">
        <div class="bfl-monthly-header">
            <div class="bfl-monthly-title">@currentT["MonthlyTitle"]</div>
            <div class="bfl-monthly-badge">@currentT["Badge"]</div>
        </div>

        <div class="bfl-monthly-card">
            <div class="bfl-monthly-top">
                <div class="bfl-monthly-date">@monthYear</div>
                <div class="bfl-monthly-total">@totalCost.ToString("N0") @currencyLabel</div>
            </div>

            <div class="bfl-monthly-metrics">
                <div class="bfl-monthly-metric-item">
                    <div class="bfl-monthly-metric-value">@totalFuel.ToString("0.0") L</div>
                    <div class="bfl-monthly-metric-label">@currentT["Fuel"]</div>
                </div>

                <div class="bfl-monthly-metric-item">
                    <div class="bfl-monthly-metric-value">@totalDistance.ToString("0.0") km</div>
                    <div class="bfl-monthly-metric-label">@currentT["Distance"]</div>
                </div>

                <div class="bfl-monthly-metric-item">
                    <div class="bfl-monthly-metric-value">@averageEfficiency.ToString("0.0") km/L</div>
                    <div class="bfl-monthly-metric-label">@currentT["Efficiency"]</div>
                </div>
            </div>

            <div class="bfl-monthly-progress"></div>
        </div>
    </div>
</div>
