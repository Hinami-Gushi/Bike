@{
    ViewData["Title"] = "Monthly Summary";

    var lang = Context.Session.GetString("lang") ?? "en";
    string currencyLabel = Context.Session.GetString("currency") ?? "USD";
    var summaries = ViewBag.MonthlySummaries;

    // Translations
    var t = new Dictionary<string, Dictionary<string, string>>
    {
        ["en"] = new() { ["MonthlyTitle"] = "Monthly Summary", ["Badge"] = "Recent months", ["Fuel"] = "Fuel", ["Distance"] = "Distance", ["Efficiency"] = "Efficiency", ["Cost"] = "Cost" },
        ["ja"] = new() { ["MonthlyTitle"] = "月間集計", ["Badge"] = "直近の月", ["Fuel"] = "給油量", ["Distance"] = "走行距離", ["Efficiency"] = "平均燃費", ["Cost"] = "費用" },
        ["vi"] = new() { ["MonthlyTitle"] = "Tổng kết hàng tháng", ["Badge"] = "Các tháng gần đây", ["Fuel"] = "Nhiên liệu", ["Distance"] = "Quãng đường", ["Efficiency"] = "Hiệu suất", ["Cost"] = "Chi phí" }
    };
    var currentT = t.ContainsKey(lang) ? t[lang] : t["en"];
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h1 class="h3 mb-0">@currentT["MonthlyTitle"]</h1>
        <p class="text-muted small mb-0">Performance breakdown by month</p>
    </div>
    <div class="col-auto">
        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success border-opacity-10">
            <i class="bi bi-calendar-check me-1"></i> @currentT["Badge"]
        </span>
    </div>
</div>

<div class="row g-3">
    @if (summaries != null)
    {
        @foreach (var s in summaries)
        {
            <div class="col-12">
                <div class="card monthly-summary-card border-0 shadow-sm overflow-hidden mb-3">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                            
                            <!-- Month/Date -->
                            <div class="d-flex align-items-center" style="min-width: 140px;">
                                <div class="bg-success bg-opacity-10 rounded-3 p-2 me-3 d-none d-sm-block">
                                    <i class="bi bi-calendar-event text-success fs-4"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-0 text-success text-nowrap">@s.MonthYear</h5>
                                    <span class="text-muted small d-none d-md-block">@TranslationHelper.T("Summary", lang)</span>
                                </div>
                            </div>

                            <!-- Metrics Section -->
                            <div class="d-flex flex-wrap justify-content-around justify-content-md-between flex-grow-1 px-md-4 gap-3">
                                
                                <div class="metric-item text-center">
                                    <div class="text-muted small fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">@currentT["Fuel"]</div>
                                    <div class="fw-bold text-dark h5 mb-0">@s.TotalFuel.ToString("0.0")<small class="ms-1 text-muted">L</small></div>
                                </div>

                                <div class="metric-item text-center">
                                    <div class="text-muted small fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">@currentT["Distance"]</div>
                                    <div class="fw-bold text-dark h5 mb-0">@s.TotalDistance.ToString("0.0")<small class="ms-1 text-muted">km</small></div>
                                </div>

                                <div class="metric-item text-center">
                                    <div class="text-success small fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">@currentT["Efficiency"]</div>
                                    <div class="fw-bold text-success h5 mb-0">@s.AverageEfficiency.ToString("0.0")<small class="ms-1">km/L</small></div>
                                </div>

                            </div>

                            <!-- Total Cost Section -->
                            <div class="ms-md-auto text-end" style="min-width: 150px;">
                                <div class="badge bg-warning bg-opacity-10 text-warning fs-5 px-3 py-2 border border-warning border-opacity-25 w-100">
                                    <span class="fw-bold">@s.TotalCost.ToString("N0")</span>
                                    <small class="ms-1 opacity-75" style="font-size: 0.7em;">@currencyLabel</small>
                                </div>
                            </div>

                        </div>
                    </div>
                    <!-- Subtle progress indicator at the bottom -->
                    <div class="progress rounded-0" style="height: 3px; opacity: 0.5;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <div class="bg-white p-5 rounded-4 shadow-sm border d-inline-block">
                <i class="bi bi-calendar-x fs-1 text-muted"></i>
                <p class="mt-3 mb-0 fw-bold text-muted">No monthly summaries available.</p>
            </div>
        </div>
    }
</div>
