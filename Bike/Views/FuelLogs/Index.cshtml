@model List<Bike.Models.FuelLog>
@using System.Globalization

@{
    ViewData["Title"] = "History";

    var lang = Context.Session.GetString("lang") ?? "en";
    string currencyLabel = Context.Session.GetString("currency") ?? "USD";

    var startDate = ViewBag.StartDate as string;
    var endDate = ViewBag.EndDate as string;

    // Aggregations from ViewBag
    double searchTotalFuel = ViewBag.SearchTotalFuel ?? 0;
    double searchTotalDistance = ViewBag.SearchTotalDistance ?? 0;
    double searchTotalJPY = ViewBag.SearchTotalJPY ?? 0;
    double searchTotalVND = ViewBag.SearchTotalVND ?? 0;
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h1 class="h3 mb-0">@TranslationHelper.T("FuelHistory", lang)</h1>
        <p class="text-muted small mb-0">Manage and search your fuel logs</p>
    </div>
    <div class="col-auto">
        <a href="/FuelLogs/Create" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-circle"></i> Add Log
        </a>
    </div>
</div>

<!-- Search & Summary -->
<div class="row g-4 mb-4">
    <div class="col-12 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Search Filters</h5>
                <form method="get" action="/FuelLogs/Index">
                    <div class="mb-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" name="startDate" class="form-control" value="@startDate">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">End Date</label>
                        <input type="date" name="endDate" class="form-control" value="@endDate">
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                        @if (ViewBag.IsSearchActive == true)
                        {
                            <a href="/FuelLogs/Index" class="btn btn-outline-secondary">Clear</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-xl-8">
        <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">Search Summary</h5>
                <div class="row g-4 text-center">
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="text-muted small fw-bold mb-1">TOTAL FUEL</div>
                            <div class="h4 mb-0 fw-bold text-success">@searchTotalFuel.ToString("0.0") L</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="text-muted small fw-bold mb-1">DISTANCE</div>
                            <div class="h4 mb-0 fw-bold text-primary">@searchTotalDistance.ToString("0.0") km</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="text-muted small fw-bold mb-1">TOTAL JPY</div>
                            <div class="h4 mb-0 fw-bold text-warning">¥@searchTotalJPY.ToString("#,0")</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded-4 bg-light">
                            <div class="text-muted small fw-bold mb-1">TOTAL VND</div>
                            <div class="h4 mb-0 fw-bold text-warning">₫@searchTotalVND.ToString("#,0")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- History Table -->
<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Fuel (L)</th>
                <th>Distance (km)</th>
                <th>Cost</th>
                <th>Efficiency</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-bold text-dark">@item.FuelDate.ToString("yyyy/MM/dd")</div>
                        <div class="text-muted small">@TranslationHelper.GetWeekday(item.FuelDate, lang)</div>
                    </td>
                    <td>
                        <span class="fw-medium">@item.FuelLiter.ToString("0.0")</span> <span class="text-muted small">L</span>
                    </td>
                    <td>
                        <span class="fw-medium">@item.DistanceKm.ToString("0.0")</span> <span class="text-muted small">km</span>
                    </td>
                    <td>
                        <span class="fw-bold text-dark">@(item.Cost?.ToString("#,0") ?? "-")</span> <span class="text-muted small">@item.Currency</span>
                    </td>
                    <td>
                        <span class="badge bg-success bg-opacity-10 text-success fs-6">
                            @item.FuelEfficiency.ToString("0.0") <small>km/L</small>
                        </span>
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a href="/FuelLogs/Edit/@item.Id" class="btn btn-light btn-sm rounded-pill px-3 border shadow-none" title="Edit">
                                <i class="bi bi-pencil-square text-primary"></i>
                            </a>
                            <form method="post" action="/FuelLogs/Delete/@item.Id" class="d-inline" onsubmit="return confirm('@TranslationHelper.T("DeleteConfirm", lang)');">
                                <button type="submit" class="btn btn-light btn-sm rounded-pill px-3 border shadow-none" title="Delete">
                                    <i class="bi bi-trash3 text-danger"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div class="bg-white p-5 rounded-4 shadow-sm border d-inline-block">
            <i class="bi bi-inbox fs-1 text-muted"></i>
            <p class="mt-3 mb-0 fw-bold text-muted">No records found for the selected criteria.</p>
        </div>
    </div>
}
