@model List<Bike.Models.FuelLog>
@using System.Globalization

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "History";

    var lang = Context.Session.GetString("lang") ?? "en";

    string currencyLabel = Context.Session.GetString("currency") ?? "USD";
    string langLabel = (lang == "ja") ? "JA" : (lang == "vi") ? "VI" : "EN";

    // Translations
    var t = new Dictionary<string, Dictionary<string, string>>
    {
        ["en"] = new() {
            ["Dashboard"] = "Dashboard", ["Add"] = "Add", ["History"] = "History", ["Monthly"] = "Monthly",
            ["HistoryTitle"] = "Fuel History", ["Records"] = "records", ["Record"] = "record",
            ["From"] = "From", ["To"] = "To", ["Search"] = "Search", ["All"] = "All",
            ["Latest10"] = "Latest 10",
            ["ConfirmDelete"] = "Are you sure you want to delete this history?",
            ["Summary"] = "Search Summary", ["TotalFuel"] = "Total Fuel", ["TotalDistance"] = "Total Distance",
            ["TotalJPY"] = "Total JPY", ["TotalVND"] = "Total VND"
        },
        ["ja"] = new() {
            ["Dashboard"] = "ダッシュボード", ["Add"] = "追加", ["History"] = "履歴", ["Monthly"] = "月間集計",
            ["HistoryTitle"] = "給油履歴", ["Records"] = "件の記録", ["Record"] = "件の記録",
            ["From"] = "開始", ["To"] = "終了", ["Search"] = "検索", ["All"] = "すべて",
            ["Latest10"] = "直近10件",
            ["ConfirmDelete"] = "この履歴を削除しますか？",
            ["Summary"] = "検索結果の集計", ["TotalFuel"] = "合計給油量", ["TotalDistance"] = "合計走行距離",
            ["TotalJPY"] = "JPY合計", ["TotalVND"] = "VND合計"
        },
        ["vi"] = new() {
            ["Dashboard"] = "Bảng điều khiển", ["Add"] = "Thêm", ["History"] = "Lịch sử", ["Monthly"] = "Hàng tháng",
            ["HistoryTitle"] = "Lịch sử Nhiên liệu", ["Records"] = "bản ghi", ["Record"] = "bản ghi",
            ["From"] = "Từ", ["To"] = "Đến", ["Search"] = "Tìm", ["All"] = "Tất cả",
            ["Latest10"] = "10 bản ghi mới nhất",
            ["ConfirmDelete"] = "Bạn có chắc chắn muốn xóa lịch sử này không?",
            ["Summary"] = "Tổng kết tìm kiếm", ["TotalFuel"] = "Tổng nhiên liệu", ["TotalDistance"] = "Tổng quãng đường",
            ["TotalJPY"] = "Tổng JPY", ["TotalVND"] = "Tổng VND"
        }
    };
    var currentT = t.ContainsKey(lang) ? t[lang] : t["en"];

    var count = Model?.Count(x => x.Currency == currencyLabel) ?? 0;
    string countSuffix = count == 1 ? currentT["Record"] : currentT["Records"];
    string countText = (ViewBag.IsSearchActive == false && count >= 10) 
        ? currentT["Latest10"] 
        : $"{count} {countSuffix}";

    var startDate = ViewBag.StartDate as string;
    var endDate = ViewBag.EndDate as string;

    // Aggregations from ViewBag
    double searchTotalFuel = ViewBag.SearchTotalFuel ?? 0;
    double searchTotalDistance = ViewBag.SearchTotalDistance ?? 0;
    double searchTotalJPY = ViewBag.SearchTotalJPY ?? 0;
    double searchTotalVND = ViewBag.SearchTotalVND ?? 0;
}

<div class="bfl-page">
    <div class="bfl-topbar">
        <div class="bfl-brand">
            <div class="bfl-brand-title is-clickable" data-bs-toggle="modal" data-bs-target="#bikeImageModal">🏍 Bike Fuel Log</div>
            <div class="bfl-brand-sub">QTSC Field Tracker</div>
        </div>

        <div class="bfl-topbar-actions">
            <div class="bfl-pill bfl-pill-currency">@currencyLabel</div>

            <div class="dropdown">
                <button class="bfl-pill bfl-pill-lang dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    @langLabel
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/Language/Set?lang=en">English</a></li>
                    <li><a class="dropdown-item" href="/Language/Set?lang=ja">日本語</a></li>
                    <li><a class="dropdown-item" href="/Language/Set?lang=vi">Tiếng Việt</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="bfl-nav">
        <a class="bfl-nav-item" href="/FuelLogs/Dashboard">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 3l9 8h-3v10h-5v-6H11v6H6V11H3l9-8z"/></svg>
            </span>
            <span class="bfl-nav-text">@TranslationHelper.T("Dashboard", lang)</span>
        </a>

        <a class="bfl-nav-item" href="/FuelLogs/Create">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M19 11H13V5h-2v6H5v2h6v6h2v-6h6v-2z"/></svg>
            </span>
            <span class="bfl-nav-text">@TranslationHelper.T("Add", lang)</span>
        </a>

        <a class="bfl-nav-item is-active" href="/FuelLogs/Index">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7 6h14v2H7V6zm0 5h14v2H7v-2zm0 5h14v2H7v-2zM3 6h2v2H3V6zm0 5h2v2H3v-2zm0 5h2v2H3v-2z"/></svg>
            </span>
            <span class="bfl-nav-text">@TranslationHelper.T("History", lang)</span>
        </a>

        <a class="bfl-nav-item" href="/FuelLogs/Monthly">
            <span class="bfl-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2zm13 8H6v10h14V10z"/></svg>
            </span>
            <span class="bfl-nav-text">@TranslationHelper.T("Monthly", lang)</span>
        </a>
    </div>

    <div class="bfl-content">
        <div class="bfl-history-header">
            <div class="d-flex align-items-center gap-2">
                <div class="bfl-history-title">@TranslationHelper.T("FuelHistory", lang)</div>
                <button class="bfl-toggle-search-btn" id="toggleSearchBtn" aria-label="Toggle Search">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                </button>
            </div>
            <div class="bfl-history-badge">@countText</div>
        </div>

        <div id="searchBox" class="bfl-search-box-compact mb-3 @(ViewBag.IsSearchActive == true ? "" : "d-none")">
            <form method="get" action="/FuelLogs/Index" class="d-flex align-items-center gap-2">
                <div class="flex-grow-1">
                    <input type="date" name="startDate" class="form-control bfl-input-sm" value="@startDate" placeholder="@currentT["From"]">
                </div>
                <div class="text-muted small">~</div>
                <div class="flex-grow-1">
                    <input type="date" name="endDate" class="form-control bfl-input-sm" value="@endDate" placeholder="@currentT["To"]">
                </div>
                <button type="submit" class="bfl-search-btn-sm">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                </button>
            </form>
        </div>

        @if (ViewBag.IsSearchActive == true)
        {
            <div class="bfl-card mb-3 p-3" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                <div class="fw-bold mb-2 text-primary" style="font-size: 0.9rem;">📊 @currentT["Summary"]</div>
                <div class="row g-2">
                    <div class="col-6">
                        <div class="small text-muted">@currentT["TotalFuel"]</div>
                        <div class="fw-bold">@searchTotalFuel.ToString("0.0") L</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">@currentT["TotalDistance"]</div>
                        <div class="fw-bold">@searchTotalDistance.ToString("0.0") km</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">@currentT["TotalJPY"]</div>
                        <div class="fw-bold text-orange">@searchTotalJPY.ToString("#,0") JPY</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">@currentT["TotalVND"]</div>
                        <div class="fw-bold text-orange">@searchTotalVND.ToString("#,0") VND</div>
                    </div>
                </div>
            </div>
        }

        <div class="bfl-history-list">
            @foreach (var item in Model)
            {
                <div class="bfl-history-card">
                    <div class="bfl-history-top">
                        <div class="bfl-history-date">@item.FuelDate.ToString("yyyy/MM/dd")</div>

                        <div class="bfl-history-actions">
                            <a class="bfl-icon-btn" href="/FuelLogs/Edit/@item.Id" aria-label="Edit">
                                <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm18-11.5a1.003 1.003 0 0 0 0-1.42l-1.34-1.34a1.003 1.003 0 0 0-1.42 0l-1.13 1.13 3.75 3.75 1.14-1.12z"/></svg>
                            </a>

                            <form method="post" action="/FuelLogs/Delete/@item.Id" class="bfl-inline" onsubmit="return confirm('@TranslationHelper.T("DeleteConfirm", lang)');">
                                <button class="bfl-icon-btn" type="submit" aria-label="Delete">
                                    <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="bfl-history-mid">
                        <div class="bfl-history-metric"><span class="bfl-dot"></span>@item.FuelLiter.ToString("0.0") L</div>
                        <div class="bfl-history-metric"><span class="bfl-dot"></span>@item.DistanceKm.ToString("0.0") km</div>
                        <div class="bfl-history-metric"><span class="bfl-dot"></span>@(item.Cost?.ToString("#,0") ?? "-") @item.Currency</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('toggleSearchBtn').addEventListener('click', function() {
            var searchBox = document.getElementById('searchBox');
            searchBox.classList.toggle('d-none');
        });
    </script>
}
