<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bike Fuel Log</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Bike.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">
    @{
        var isAuthPage = ViewData["HideNav"]?.ToString() == "true";
        var userEmail = Context.Session.GetString("userEmail");
        var showSidebar = !isAuthPage && !string.IsNullOrEmpty(userEmail);
    }
    <div class="d-flex flex-column flex-md-row min-vh-100">
        @if (showSidebar)
        {
            <!-- Sidebar for Desktop / Hidden on Mobile -->
            <aside class="sidebar bg-white border-end d-none d-md-flex flex-column" style="width: 260px; position: sticky; top: 0; height: 100vh;">
                <div class="p-4 border-bottom">
                    <a class="navbar-brand d-flex align-items-center gap-2 fw-bold text-success fs-4" asp-area="" asp-controller="FuelLogs" asp-action="Dashboard">
                        <span class="fs-2">🏍</span>
                        <span>Bike Log</span>
                    </a>
                </div>
                <div class="flex-grow-1 p-3">
                    <nav class="nav nav-pills flex-column gap-2">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "text-dark") px-3 py-2 rounded-3 d-flex align-items-center gap-3" asp-controller="FuelLogs" asp-action="Dashboard">
                            <i class="bi bi-speedometer2 fs-5"></i> Dashboard
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "active" : "text-dark") px-3 py-2 rounded-3 d-flex align-items-center gap-3" asp-controller="FuelLogs" asp-action="Create">
                            <i class="bi bi-plus-circle fs-5"></i> Add Log
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "text-dark") px-3 py-2 rounded-3 d-flex align-items-center gap-3" asp-controller="FuelLogs" asp-action="Index">
                            <i class="bi bi-list-ul fs-5"></i> History
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Monthly" ? "active" : "text-dark") px-3 py-2 rounded-3 d-flex align-items-center gap-3" asp-controller="FuelLogs" asp-action="Monthly">
                            <i class="bi bi-calendar3 fs-5"></i> Monthly
                        </a>
                    </nav>
                </div>
                <div class="p-3 border-top mt-auto">
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center link-dark text-decoration-none dropdown-toggle px-2 py-1 rounded" id="dropdownUser2" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <span class="small fw-semibold text-truncate" style="max-width: 140px;">@userEmail</span>
                        </a>
                        <ul class="dropdown-menu shadow border-0" aria-labelledby="dropdownUser2">
                            <li><a class="dropdown-item py-2 text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                </div>
            </aside>
        }

        <!-- Main Content -->
        <main class="flex-grow-1 d-flex flex-column">
            @if (showSidebar)
            {
                <!-- Mobile Top Navbar -->
                <header class="navbar navbar-expand-md navbar-light bg-white border-bottom d-md-none p-3 sticky-top">
                    <div class="container-fluid p-0">
                        <a class="navbar-brand fw-bold text-success d-flex align-items-center gap-2" href="/FuelLogs/Dashboard">
                            <span>🏍</span> Bike Log
                        </a>
                        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMobile" aria-controls="navbarMobile" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse mt-3" id="navbarMobile">
                            <ul class="navbar-nav gap-2">
                                <li class="nav-item">
                                    <a class="nav-link rounded-3 px-3 py-2 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "bg-success bg-opacity-10 text-success fw-bold" : "")" href="/FuelLogs/Dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link rounded-3 px-3 py-2 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "bg-success bg-opacity-10 text-success fw-bold" : "")" href="/FuelLogs/Create">Add Log</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link rounded-3 px-3 py-2 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "bg-success bg-opacity-10 text-success fw-bold" : "")" href="/FuelLogs/Index">History</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link rounded-3 px-3 py-2 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Monthly" ? "bg-success bg-opacity-10 text-success fw-bold" : "")" href="/FuelLogs/Monthly">Monthly</a>
                                </li>
                                <li class="border-top mt-2 pt-2">
                                    <a class="nav-link text-danger px-3" href="/Account/Logout">Logout</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </header>
            }

            <div class="container-fluid p-3 p-md-5">
                @RenderBody()
            </div>

            @if (showSidebar)
            {
                <!-- Mobile Bottom Nav -->
                <nav class="d-md-none bg-white border-top fixed-bottom py-2 shadow-lg">
                    <div class="container d-flex justify-content-around text-center">
                        <a href="/FuelLogs/Dashboard" class="text-decoration-none @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "text-success fw-bold" : "text-muted") small">
                            <i class="bi bi-speedometer2 d-block fs-4"></i>
                            Dashboard
                        </a>
                        <a href="/FuelLogs/Create" class="text-decoration-none @(ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "text-success fw-bold" : "text-muted") small">
                            <i class="bi bi-plus-circle d-block fs-4"></i>
                            Add
                        </a>
                        <a href="/FuelLogs/Index" class="text-decoration-none @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "text-success fw-bold" : "text-muted") small">
                            <i class="bi bi-list-ul d-block fs-4"></i>
                            History
                        </a>
                        <a href="/FuelLogs/Monthly" class="text-decoration-none @(ViewContext.RouteData.Values["Action"]?.ToString() == "Monthly" ? "text-success fw-bold" : "text-muted") small">
                            <i class="bi bi-calendar3 d-block fs-4"></i>
                            Monthly
                        </a>
                    </div>
                </nav>
            }
        </main>
    </div>

    <!-- Bike Image Modal -->
    <div class="modal fade" id="bikeImageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 text-center">
                    <img src="~/images/IMG_0496.jpeg" class="img-fluid rounded-bottom" alt="My Bike" style="max-height: 80vh; width: 100%; object-fit: cover;">
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>