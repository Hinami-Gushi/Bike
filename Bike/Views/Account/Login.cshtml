@{
    ViewData["Title"] = "Login";
    ViewData["HideNav"] = "true";
    var lang = Context.Session.GetString("lang") ?? "en";

    var t = new Dictionary<string, Dictionary<string, string>>
    {
        ["en"] = new() { ["Login"] = "Login", ["Email"] = "Email", ["Password"] = "Password", ["NoAccount"] = "Don't have an account?", ["Register"] = "Register here", ["ErrInvalidAuth"] = "Invalid email or password.", ["Welcome"] = "Welcome Back" },
        ["ja"] = new() { ["Login"] = "ログイン", ["Email"] = "メールアドレス", ["Password"] = "パスワード", ["NoAccount"] = "アカウントをお持ちでない方", ["Register"] = "新規登録はこちら", ["ErrInvalidAuth"] = "メールアドレスまたはパスワードが正しくありません。", ["Welcome"] = "おかえりなさい" },
        ["vi"] = new() { ["Login"] = "Đăng nhập", ["Email"] = "Email", ["Password"] = "Mật khẩu", ["NoAccount"] = "Chưa có tài khoản?", ["Register"] = "Đăng ký tại đây", ["ErrInvalidAuth"] = "Email hoặc mật khẩu không đúng.", ["Welcome"] = "Chào mừng quay trở lại" }
    };
    var currentT = t.ContainsKey(lang) ? t[lang] : t["en"];

    string errorMsg = "";
    if (ViewBag.ErrorKey != null && currentT.ContainsKey(ViewBag.ErrorKey)) {
        errorMsg = currentT[ViewBag.ErrorKey];
    }
}

<div class="row justify-content-center align-items-center min-vh-100 py-3">
    <div class="col-12" style="max-width: 1000px; width: 90%;">
        <div class="text-center mb-5">
            <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle mb-3" style="width: 80px; height: 80px;">
                <span class="fs-1">🏍</span>
            </div>
            <h1 class="fw-bold h2">@currentT["Welcome"]</h1>
            <p class="text-muted">Manage your bike's fuel efficiency with ease</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-4 p-md-5">
                        <h2 class="h4 fw-bold mb-4 text-center text-md-start">@currentT["Login"]</h2>
                        
                        @if (!string.IsNullOrEmpty(errorMsg)) {
                            <div class="alert alert-danger border-0 shadow-sm rounded-3 small py-2 text-center">
                                <i class="bi bi-exclamation-circle-fill me-2"></i> @errorMsg
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            <div class="mb-3">
                                <label class="form-label">@currentT["Email"]</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                                    <input class="form-control border-start-0 ps-0" type="email" name="email" placeholder="name@example.com" required />
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">@currentT["Password"]</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-shield-lock"></i></span>
                                    <input class="form-control border-start-0 ps-0" type="password" name="password" placeholder="••••••••" required />
                                </div>
                            </div>
                            <div class="d-grid mb-4">
                                <button class="btn btn-success btn-lg py-3 shadow-sm fw-bold" type="submit">
                                    @currentT["Login"]
                                </button>
                            </div>
                        </form>

                        <div class="text-center">
                            <p class="text-muted small mb-0">
                                @currentT["NoAccount"] <a href="/Account/Register" class="text-success fw-bold text-decoration-none">@currentT["Register"]</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 text-center">
            <div class="btn-group shadow-sm rounded-pill overflow-hidden bg-white p-1">
                <a class="btn btn-sm @(lang == "en" ? "btn-success" : "btn-white border-0 text-muted") rounded-pill px-3" href="/Language/Set?lang=en">EN</a>
                <a class="btn btn-sm @(lang == "ja" ? "btn-success" : "btn-white border-0 text-muted") rounded-pill px-3" href="/Language/Set?lang=ja">JA</a>
                <a class="btn btn-sm @(lang == "vi" ? "btn-success" : "btn-white border-0 text-muted") rounded-pill px-3" href="/Language/Set?lang=vi">VI</a>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-white { background: white; }
    .btn-white:hover { background: #f8fafc; }
</style>
